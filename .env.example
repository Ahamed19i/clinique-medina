# Configuration SMTP pour l'envoi d'e-mails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-d-application
SMTP_FROM=Clinique de la Médina <votre-email@gmail.com>
SMTP_TO=contact@ahamedhassani.com

# Sécurité
# Liste des domaines autorisés séparés par des virgules (ex: https://mon-domaine.com)
# Si vide, autorise toutes les origines (moins sécurisé)
ALLOWED_ORIGINS=
